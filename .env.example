# =============================================================================
# Cypress Zero-Ops — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All ports are in the 7000 range to avoid collisions with other local services.
# =============================================================================

# -----------------------------------------------------------------------------
# PHASE 1 — Foundation: PostgreSQL, Redis, Logto, Novu, n8n
# -----------------------------------------------------------------------------

# --- PostgreSQL (shared instance, separate logical databases) ---
POSTGRES_USER=cypress
POSTGRES_PASSWORD=cypress_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Logto (Auth & RBAC) ---
# Logto requires its own database within the shared PostgreSQL instance
LOGTO_DB_URL=postgres://cypress:cypress_dev_password@postgres:5432/logto
LOGTO_ENDPOINT=http://localhost:7001
LOGTO_ADMIN_ENDPOINT=http://localhost:7002
# Generate with: openssl rand -hex 32
LOGTO_ADMIN_CONSOLE_REDIRECT_URI=http://localhost:7002/callback
# Connector secrets (fill when configuring social login)
LOGTO_GOOGLE_CLIENT_ID=
LOGTO_GOOGLE_CLIENT_SECRET=

# --- n8n (Workflow Orchestration) ---
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=cypress
N8N_DB_POSTGRESDB_PASSWORD=cypress_dev_password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:7678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cypress_n8n_dev
N8N_ENCRYPTION_KEY=change-me-to-a-random-string

# --- Novu (Notifications) ---
NOVU_API_KEY=
NOVU_SECRET_KEY=change-me-to-a-random-string
NOVU_MONGO_URL=
# Novu self-hosted uses MongoDB — we use the embedded one in docker-compose
# Provider: Resend (Email)
RESEND_API_KEY=
# Provider: Slack (Webhooks)
SLACK_WEBHOOK_URL=

# --- Cypress Core Integration ---
CYPRESS_CORE_API_URL=http://host.docker.internal:3000
CYPRESS_CORE_API_KEY=
CYPRESS_CORE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# PHASE 2 — Contracts & Billing: DocuSeal, Lago
# -----------------------------------------------------------------------------

# --- DocuSeal (Contract Signing) ---
DOCUSEAL_SECRET_KEY=change-me-to-a-random-string
DOCUSEAL_HOST=http://localhost:7020

# --- Lago (Billing & Metering) ---
LAGO_DB_HOST=lago-db
LAGO_DB_PORT=5432
LAGO_DB_USER=lago
LAGO_DB_PASSWORD=lago_dev_password
LAGO_DB_NAME=lago
LAGO_REDIS_HOST=lago-redis
LAGO_REDIS_PORT=6379
LAGO_API_URL=http://localhost:7030
LAGO_FRONT_URL=http://localhost:7031
LAGO_RSA_PRIVATE_KEY=
LAGO_SECRET_KEY_BASE=change-me-to-a-random-string
LAGO_ENCRYPTION_PRIMARY_KEY=change-me-primary-key
LAGO_ENCRYPTION_DETERMINISTIC_KEY=change-me-deterministic-key
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=change-me-derivation-salt

# -----------------------------------------------------------------------------
# PHASE 3 — CRM: Twenty
# -----------------------------------------------------------------------------

# --- Twenty CRM ---
TWENTY_DB_HOST=postgres
TWENTY_DB_PORT=5432
TWENTY_DB_USER=cypress
TWENTY_DB_PASSWORD=cypress_dev_password
TWENTY_DB_NAME=twenty
TWENTY_SERVER_URL=http://localhost:7040
TWENTY_FRONT_AUTH_CALLBACK_URL=http://localhost:7040/verify
TWENTY_ACCESS_TOKEN_SECRET=change-me-access-token-secret
TWENTY_LOGIN_TOKEN_SECRET=change-me-login-token-secret
TWENTY_REFRESH_TOKEN_SECRET=change-me-refresh-token-secret
TWENTY_FILE_TOKEN_SECRET=change-me-file-token-secret

# -----------------------------------------------------------------------------
# PHASE 4 — Payments & Accounting: Stripe, QuickBooks
# -----------------------------------------------------------------------------

# --- Stripe ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- QuickBooks ---
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:7678/webhook/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox
